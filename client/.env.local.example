# Public — exposed to the browser
NEXT_PUBLIC_API_BASE=http://localhost:8088

# Optional: override the URL Next.js server-side fetches use to reach the API.
# Only set this when the API is on a different hostname from the browser's
# perspective (e.g. inside Docker compose where the service is named `api`).
# Defaults to NEXT_PUBLIC_API_BASE when unset.
# API_BASE_INTERNAL=http://api:8000
