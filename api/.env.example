# Application
APP_NAME="Feature Flag Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8088

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# Database — SQLite by default. Mount a persistent volume in production.
DB_CONNECTION=sqlite
# DB_DATABASE=/var/lib/sqlite/database.sqlite

# Cache / queue / session — for the demo the flag-set cache is the only one
# that matters; everything else is no-op driven.
CACHE_STORE=redis
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

# Redis — used by FlagCache for stampede-safe storage of the flag set.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# CORS — comma-separated allow-list of origins for the public API.
FRONTEND_ORIGIN=http://localhost:3000

# Feature-flag service tuning. Defaults work for the demo; raise the cache TTL
# in production and lower the decision-log sample rate at scale.
FLAG_CACHE_TTL=900
FLAG_CACHE_LOCK_TTL=5
FLAG_CACHE_LOCK_WAIT=3
FLAG_PUBLIC_RESPONSE_CACHE_SECONDS=15
FLAG_DECISION_LOG_SAMPLE_RATE=1.0
FLAG_DECISION_LOG_RETENTION_DAYS=30
FLAG_EVALUATE_RATE_LIMIT=60

# Sanctum personal-access-token TTL (minutes).
SANCTUM_TOKEN_EXPIRATION_MINUTES=60
